def cmd_sns_images(args):
    """批量解密 cache/<YYYY-MM>/Sns/Img 下所有图片。

    XML md5 跟 cache 文件名对不上号（CDN 内部哈希），所以做不到"按朋友圈反查"。
    务实路径：按月份扫整个 Sns/Img 目录，全部 v2 解密成 JPEG，按源文件 mtime 命名。
    """
    import json as _json
    from vchat_core import image_codec as decode_image

    cfg = _json.loads((PROJECT_DIR / "config.json").read_text())
    aes_key = cfg.get("image_aes_key")
    xor_key = cfg.get("image_xor_key", 0x88)
    if not aes_key:
        print(f"config.json 缺 image_aes_key。先跑: cd {PROJECT_DIR} && .venv/bin/python find_image_key_macos.py", file=sys.stderr)
        sys.exit(2)

    wxid_dir = Path(cfg["db_dir"]).parent  # xwechat_files/<wxid>/
    cache_root = wxid_dir / "cache"
    if not cache_root.exists():
        print(f"找不到 {cache_root}", file=sys.stderr)
        sys.exit(2)

    month_filter = args.target  # e.g. "2026-05"，None 表示全部
    out_dir = Path(args.output or "~/Downloads/wx-sns-images").expanduser().resolve()
    out_dir.mkdir(parents=True, exist_ok=True)

    months = sorted([d for d in cache_root.iterdir() if d.is_dir() and (month_filter is None or d.name == month_filter)])
    if not months:
        print(f"cache 下没匹配的月份目录（filter={month_filter}）", file=sys.stderr)
        sys.exit(2)

    total_ok = total_fail = 0
    for month_dir in months:
        img_dir = month_dir / "Sns" / "Img"
        if not img_dir.exists():
            continue
        month_out = out_dir / month_dir.name
        month_out.mkdir(parents=True, exist_ok=True)
        for f in img_dir.rglob("*"):
            if not f.is_file():
                continue
            try:
                ts = int(f.stat().st_mtime)
                stem = datetime.fromtimestamp(ts).strftime("%m%d_%H%M%S") + "_" + f.name[:8]
                # decode_image 自己处理 V1/V2/XOR，传 aes_key + xor_key
                out_path, fmt = decode_image.decrypt_dat(
                    str(f), str(month_out / f"{stem}.tmp"),
                    aes_key=aes_key, xor_key=xor_key
                )
                if out_path:
                    # 改名加正确后缀
                    final = month_out / f"{stem}.{fmt}"
                    Path(out_path).rename(final)
                    total_ok += 1
                else:
                    total_fail += 1
            except Exception as e:
                total_fail += 1
        print(f"{month_dir.name}: 累计 ok={total_ok} fail={total_fail}")

    print(f"\n完成。{total_ok} 张图导出到 {out_dir}，{total_fail} 失败/非 V2 格式")


def _parse_sns_xml(content_xml):
    """SnsTimeLine.content 是 <SnsDataItem><TimelineObject>...</TimelineObject></SnsDataItem>"""
    import xml.etree.ElementTree as ET
    try:
        root = ET.fromstring(content_xml)
    except ET.ParseError:
        return None
    obj = root.find("TimelineObject")
    if obj is None:
        obj = root
    media_types = {1: "img", 2: "img", 6: "video", 7: "link", 8: "link"}
    medias = []
    for m in obj.findall(".//mediaList/media"):
        t = int(m.findtext("type") or "0")
        medias.append(media_types.get(t, f"type{t}"))
    loc = obj.find("location")
    poi = loc.get("poiName") if loc is not None else ""
    return {
        "id": obj.findtext("id") or "",
        "username": obj.findtext("username") or "",
        "create_time": int(obj.findtext("createTime") or 0),
        "text": (obj.findtext("contentDesc") or "").strip(),
        "private": (obj.findtext("private") or "0") == "1",
        "media": medias,
        "poi": poi or "",
    }


def cmd_sns(args):
    """朋友圈 ls/user/search/mentions/export"""
    check_freshness()
    import sqlite3, os as _os
    from vchat_core import _compat as mcp_server
    db = mcp_server._cache.get(_os.path.join("sns", "sns.db"))
    if not db:
        print("DBCache 拿不到 sns.db", file=sys.stderr)
        sys.exit(2)

    try:
        names = mcp_server.get_contact_names() or {}
    except Exception:
        names = {}

    def display(uname):
        return names.get(uname) or uname

    def render(uname, parsed):
        when = datetime.fromtimestamp(parsed["create_time"]).strftime("%Y-%m-%d %H:%M") if parsed["create_time"] else "?"
        head = f"[{when}] {display(uname)}"
        if parsed["private"]:
            head += " 🔒"
        if parsed["media"]:
            head += f"  📎{','.join(parsed['media'])}"
        if parsed["poi"]:
            head += f"  📍{parsed['poi']}"
        text = parsed["text"]
        if args.action != "export" and len(text) > 200:
            text = text[:200] + "…"
        return f"{head}\n  {text.replace(chr(10), chr(10) + '  ')}\n"

    with sqlite3.connect(db) as conn:
        if args.action == "ls":
            rows = conn.execute(
                "SELECT user_name, content FROM SnsTimeLine ORDER BY tid DESC LIMIT ?",
                (args.n or 20,)
            ).fetchall()
        elif args.action in ("user", "export"):
            ctx = mcp_server._resolve_chat_context(args.target)
            if not ctx:
                print(f"找不到联系人: {args.target}", file=sys.stderr)
                sys.exit(2)
            rows = conn.execute(
                "SELECT user_name, content FROM SnsTimeLine WHERE user_name = ? ORDER BY tid DESC LIMIT ?",
                (ctx["username"], args.n or 100)
            ).fetchall()
        elif args.action == "search":
            rows = conn.execute(
                "SELECT user_name, content FROM SnsTimeLine WHERE content LIKE ? ORDER BY tid DESC LIMIT ?",
                (f"%{args.target}%", args.n or 30)
            ).fetchall()
        elif args.action == "images":
            cmd_sns_images(args)
            return
        elif args.action == "mentions":
            mrows = conn.execute(
                "SELECT create_time, type, from_username, from_nickname, content FROM SnsMessage_tmp3 ORDER BY create_time DESC LIMIT ?",
                (args.n or 20,)
            ).fetchall()
            type_map = {1: "评论", 2: "点赞", 3: "@我"}
            for ct, t, fu, fn, c in mrows:
                when = datetime.fromtimestamp(ct).strftime("%Y-%m-%d %H:%M") if ct else "?"
                tag = type_map.get(t, f"type{t}")
                who = fn or display(fu)
                msg = f": {c}" if c else ""
                print(f"[{when}] {tag} 来自 {who}{msg}")
            return
        else:
            print(f"未知 action: {args.action}", file=sys.stderr)
            sys.exit(2)

    parsed_rows = []
    for uname, content in rows:
        p = _parse_sns_xml(content)
        if p:
            parsed_rows.append((uname, p))

    if args.action == "export":
        out_path = Path(args.output or f"{args.target}_sns.md").expanduser().resolve()
        lines = [f"# {args.target} 的朋友圈", "", f"> 导出于 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}  共 {len(parsed_rows)} 条", ""]
        for uname, p in parsed_rows:
            lines.append("---")
            lines.append(render(uname, p))
        out_path.write_text("\n".join(lines), encoding="utf-8")
        print(f"导出到 {out_path}（{len(parsed_rows)} 条）")
        return

    if not parsed_rows:
        print("（无结果）")
        return
    for uname, p in parsed_rows:
        print(render(uname, p))


def cmd_files(args):
    """聊天里收发过的图片/视频/文件，基于 hardlink.db 索引

    vchat files <chat>                列某人/某群的图/视频/文件
    vchat files <chat> -k video       只看视频
    vchat files <chat> --export -o d  解密导出到目录
    """
    check_freshness()
    import sqlite3, hashlib, json
    from pathlib import Path as _P
    from vchat_core import image_codec as decode_image
    from vchat_core import _compat as mcp_server
    db = mcp_server._cache.get(os.path.join("hardlink", "hardlink.db"))
    if not db:
        print("拿不到 hardlink.db", file=sys.stderr); sys.exit(2)

    ctx = mcp_server._resolve_chat_context(args.target)
    if not ctx:
        print(f"找不到聊天对象: {args.target}", file=sys.stderr); sys.exit(2)
    username = ctx["username"]
    chat_hash = hashlib.md5(username.encode()).hexdigest()

    kind = args.kind or "all"
    tables = {"image": "image_hardlink_info_v4", "video": "video_hardlink_info_v4", "file": "file_hardlink_info_v4"}
    target_tables = [tables[kind]] if kind != "all" else list(tables.values())

    cfg = json.loads((PROJECT_DIR / "config.json").read_text())
    wxid_dir = _P(cfg["db_dir"]).parent
    aes_key = cfg.get("image_aes_key")
    xor_key = cfg.get("image_xor_key", 0x88)

    sub_dirs = {"image_hardlink_info_v4": "Img", "video_hardlink_info_v4": "Video", "file_hardlink_info_v4": "File"}

    conn = sqlite3.connect(db)
    # 找 chat_hash 对应的 dir2id rowid
    r = conn.execute("SELECT rowid FROM dir2id WHERE username=?", (chat_hash,)).fetchone()
    if not r:
        print(f"{ctx['display_name']} 在 hardlink.db 里没有附件记录")
        return
    dir1_rowid = r[0]

    all_items = []
    for tbl in target_tables:
        for fname, fsize, mtime, dir2 in conn.execute(
            f"SELECT file_name, file_size, modify_time, dir2 FROM {tbl} WHERE dir1=? ORDER BY modify_time DESC",
            (dir1_rowid,)
        ).fetchall():
            month = conn.execute("SELECT username FROM dir2id WHERE rowid=?", (dir2,)).fetchone()
            month = month[0] if month else "?"
            sub = sub_dirs[tbl]
            full_path = wxid_dir / "msg/attach" / chat_hash / month / sub / fname
            all_items.append((tbl, fname, fsize, mtime, month, full_path))

    if not all_items:
        print(f"{ctx['display_name']} 没有 {kind} 类型附件")
        return

    if not args.export:
        print(f"{ctx['display_name']} 的附件（共 {len(all_items)} 项）:\n")
        for tbl, fname, fsize, mtime, month, full in all_items[:args.n or 50]:
            t = tbl.split("_")[0]
            when = datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M") if mtime else "?"
            mb = fsize / 1024 / 1024 if fsize else 0
            mark = "✓" if full.exists() else "✗(本地缺)"
            print(f"  [{when}] [{t}] {mb:6.2f}MB  {fname}  {mark}")
        return

    # export
    out_dir = _P(args.output or f"~/Downloads/wx-files-{args.target}").expanduser().resolve()
    out_dir.mkdir(parents=True, exist_ok=True)
    ok = fail = missing = 0
    for tbl, fname, fsize, mtime, month, full in all_items:
        if not full.exists():
            missing += 1; continue
        t = tbl.split("_")[0]
        stem = datetime.fromtimestamp(mtime).strftime("%Y%m%d_%H%M%S") if mtime else "noTS"
        try:
            if t == "image":
                # V2 .dat 解密
                out_path, fmt = decode_image.decrypt_dat(
                    str(full), str(out_dir / f"{stem}_{fname[:8]}.tmp"),
                    aes_key=aes_key, xor_key=xor_key
                )
                if out_path:
                    final = out_dir / f"{stem}_{fname[:8]}.{fmt}"
                    _P(out_path).rename(final)
                    ok += 1
                else:
                    fail += 1
            else:
                # 文件/视频通常不加密，直接 copy
                import shutil
                ext = full.suffix or (".mp4" if t == "video" else ".bin")
                shutil.copy(str(full), str(out_dir / f"{stem}_{fname[:20]}{ext}"))
                ok += 1
        except Exception as e:
            fail += 1
    print(f"完成。{ok} ok / {fail} 失败 / {missing} 本地缺失 → {out_dir}")


def cmd_solitaire(args):
    """群接龙 ls/show"""
    check_freshness()
    import sqlite3, hashlib
    from vchat_core import _compat as mcp_server
    db = mcp_server._cache.get(os.path.join("solitaire", "solitaire.db"))
    if not db:
        print("拿不到 solitaire.db", file=sys.stderr); sys.exit(2)
    names = mcp_server.get_contact_names() or {}

    conn = sqlite3.connect(db)
    # 表名是 Solitaire_<hash> / SolitaireValid_<hash> / SolitaireFold_<hash>
    sol_tables = [r[0] for r in conn.execute(
        "SELECT name FROM sqlite_master WHERE type='table' AND name LIKE 'Solitaire\\_%' ESCAPE '\\'"
    ).fetchall()]
    hashes = sorted({t.replace("Solitaire_", "") for t in sol_tables})

    # 反查 hash → group username
    msg_db = mcp_server._cache.get(os.path.join("message", "message_0.db"))
    h2u = {}
    if msg_db:
        for r in sqlite3.connect(msg_db).execute("SELECT user_name FROM Name2Id"):
            h2u[hashlib.md5(r[0].encode()).hexdigest()] = r[0]

    if args.action == "ls":
        print(f"有接龙的群（共 {len(hashes)} 个）:\n")
        for h in hashes:
            tbl = f"Solitaire_{h}"
            cnt = conn.execute(f'SELECT COUNT(*) FROM "{tbl}"').fetchone()[0]
            uname = h2u.get(h, "?")
            display = names.get(uname) or uname
            print(f"  {cnt:3d} 条接龙  {display}")
        return

    if args.action == "show":
        if not args.target:
            print("show 需要群名", file=sys.stderr); sys.exit(2)
        ctx = mcp_server._resolve_chat_context(args.target)
        if not ctx:
            print(f"找不到群: {args.target}", file=sys.stderr); sys.exit(2)
        h = hashlib.md5(ctx["username"].encode()).hexdigest()
        tbl = f"Solitaire_{h}"
        if tbl not in sol_tables:
            print(f"{ctx['display_name']} 没有接龙记录")
            return
        rows = conn.execute(
            f'SELECT header, footer, content, active_time FROM "{tbl}" ORDER BY active_time DESC LIMIT ?',
            (args.n or 20,)
        ).fetchall()
        print(f"{ctx['display_name']} 的接龙（{len(rows)} 条）:\n")
        for header, footer, content, ts in rows:
            when = datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M") if ts else "?"
            print(f"[{when}] {header}")
            if content:
                for line in content.split("\n")[:8]:
                    if line.strip():
                        print(f"  {line.strip()}")
            print()


def cmd_voice(args):
    """语音消息列表/导出。媒体在 media_0.db.VoiceInfo（305 条），mcp_server 有 decode/transcribe tool"""
    check_freshness()
    import sqlite3, hashlib
    from vchat_core import _compat as mcp_server
    db = mcp_server._cache.get(os.path.join("message", "media_0.db"))
    if not db:
        print("拿不到 media_0.db", file=sys.stderr); sys.exit(2)
    names = mcp_server.get_contact_names() or {}
    conn = sqlite3.connect(db)

    if args.action == "stats":
        total = conn.execute("SELECT COUNT(*) FROM VoiceInfo").fetchone()[0]
        print(f"本机缓存语音消息：{total} 条")
        # 按 chat_name_id 分组 top
        rows = conn.execute(
            "SELECT n.user_name, COUNT(*) FROM VoiceInfo v JOIN Name2Id n ON n.rowid=v.chat_name_id "
            "GROUP BY v.chat_name_id ORDER BY COUNT(*) DESC LIMIT 10"
        ).fetchall()
        print("\n各聊天对象的语音数 top 10:")
        for uname, cnt in rows:
            print(f"  {cnt:3d}  {names.get(uname) or uname}")
        return

    if args.action == "ls":
        ctx = mcp_server._resolve_chat_context(args.target)
        if not ctx:
            print(f"找不到: {args.target}", file=sys.stderr); sys.exit(2)
        rows = conn.execute(
            "SELECT v.local_id, v.create_time, length(v.voice_data) FROM VoiceInfo v "
            "JOIN Name2Id n ON n.rowid=v.chat_name_id WHERE n.user_name=? "
            "ORDER BY v.create_time DESC LIMIT ?",
            (ctx["username"], args.n or 30)
        ).fetchall()
        if not rows:
            print(f"{ctx['display_name']} 没有缓存的语音")
            return
        print(f"{ctx['display_name']} 的语音（{len(rows)} 条）:\n")
        for lid, ct, size in rows:
            when = datetime.fromtimestamp(ct).strftime("%Y-%m-%d %H:%M") if ct else "?"
            kb = (size or 0) / 1024
            print(f"  local_id={lid}  [{when}]  {kb:.1f}KB")
        print("\n提示: vchat voice transcribe <name> --local-id N  转录单条；CC 内调 MCP transcribe_voice 批量")
        return

    if args.action == "transcribe":
        if not args.target or args.local_id is None:
            print("transcribe 需要 <name> --local-id N", file=sys.stderr); sys.exit(2)
        text = mcp_server.transcribe_voice(args.target, args.local_id)
        print(text)
        return



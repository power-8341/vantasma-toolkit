_TYPE_TAG = {1: "", 3: "[图片]", 34: "[语音]", 43: "[视频]", 47: "[表情]", 49: "[链接/文件]"}


def json_to_md(in_json, out_md):
    data = json.loads(Path(in_json).read_text(encoding="utf-8"))
    is_group = data.get("is_chatroom", data.get("is_group", False))
    title = data.get("display_name") or data.get("chat_name") or "聊天记录"
    exported = data.get("exported_at", 0)
    when = datetime.fromtimestamp(exported).strftime("%Y-%m-%d %H:%M") if exported else ""
    lines = [f"# {title}", "", f"> 导出于 {when}  共 {len(data['messages'])} 条", ""]
    for m in data["messages"]:
        ts = datetime.fromtimestamp(m["create_time"]).strftime("%m-%d %H:%M")
        sender = m.get("sender_name") or "—"
        local_type = m.get("local_type", 1)
        content = (m.get("content") or "").strip()
        prefix = f"**{ts}** {sender}: " if is_group or sender == "me" else f"**{ts}** "
        if local_type == 1:
            lines.append(prefix + content)
        else:
            tag = _TYPE_TAG.get(local_type, f"[type={local_type}]")
            lines.append(prefix + (f"{tag} {content}" if content else tag))
    Path(out_md).write_text("\n\n".join(lines), encoding="utf-8")



            args.func(args); return
        import io, contextlib
        buf = io.StringIO()
        rc = 0
        try:
            with contextlib.redirect_stdout(buf):
                args.func(args)
        except SystemExit as e:
            rc = e.code if isinstance(e.code, int) else 1
        json.dump({"command": args.cmd, "output_text": buf.getvalue(),

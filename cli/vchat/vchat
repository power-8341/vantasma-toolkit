def _pb_parse(data, depth=0):
    """Raw protobuf scanner. 返回 list[(field, type, value)]"""
    i = 0
    out = []
    while i < len(data):
        b = data[i]; i += 1
        shift = 7
        while b & 0x80 and i < len(data):
            b = (b & 0x7f) | (data[i] << shift)
            i += 1; shift += 7
        field = b >> 3
        wire = b & 7
        if wire == 0:
            v = 0; shift = 0
            while i < len(data):
                bb = data[i]; i += 1
                v |= (bb & 0x7f) << shift
                if not (bb & 0x80): break
                shift += 7
            out.append((field, 'varint', v))
        elif wire == 2:
            L = 0; shift = 0
            while i < len(data):
                bb = data[i]; i += 1
                L |= (bb & 0x7f) << shift
                if not (bb & 0x80): break
                shift += 7
            chunk = data[i:i+L]; i += L
            try:
                s = chunk.decode('utf-8')
                if all(c.isprintable() or c in '\n\t' for c in s) and s:
                    out.append((field, 'str', s)); continue
            except UnicodeDecodeError:
                pass
            if depth < 3:
                nested = _pb_parse(chunk, depth+1)
                if nested:
                    out.append((field, 'nested', nested)); continue
            out.append((field, 'bytes', chunk))
        elif wire == 1: i += 8
        elif wire == 5: i += 4
        else: break
    return out



    if args.action == "export":
        if not args.target:
            print("❌ vchat emoji-export <package_id 或 'all'>", file=sys.stderr); sys.exit(2)
        import urllib.request
        out_dir = Path(args.output or "~/Downloads/vchat-emoji").expanduser().resolve()
        out_dir.mkdir(parents=True, exist_ok=True)
        if args.target == "all":
            rows = conn.execute("SELECT package_id_, md5_, caption_ FROM kStoreEmoticonCaptionsTable").fetchall()
        else:
            rows = conn.execute("SELECT package_id_, md5_, caption_ FROM kStoreEmoticonCaptionsTable WHERE package_id_=?", (args.target,)).fetchall()
        if not rows:
            print(f"❌ 找不到: {args.target}", file=sys.stderr); sys.exit(2)
        url_by_md5 = {r[0]: r[1] for r in conn.execute("SELECT md5, cdn_url FROM kNonStoreEmoticonTable WHERE cdn_url IS NOT NULL").fetchall()}
        print(f"试下载 {len(rows)} 张到 {out_dir}…")
        ok = miss = fail = 0
        for pkg_id, md5, caption in rows[:args.n or 200]:
            url = url_by_md5.get(md5)
            if not url:
                miss += 1; continue
            try:
                safe_cap = (caption or md5[:8]).replace("/", "_").replace(" ", "")[:30]
                urllib.request.urlretrieve(url, str(out_dir / f"{safe_cap}_{md5[:8]}.gif"))
                ok += 1
            except Exception:
                fail += 1
        print(f"✅ {ok} 下载 / {miss} 缺 cdn_url / {fail} 失败")



            cnt = conn.execute(f'SELECT COUNT(*) FROM "{t}"').fetchone()[0]
            if cnt == 0: continue
            total_chats += 1
            total_msgs += cnt
            # 我发的（real_sender_id 关联 SELF）
            sent = conn.execute(
                f'SELECT COUNT(*) FROM "{t}" WHERE real_sender_id IN ('
                f'SELECT rowid FROM Name2Id WHERE user_name=?)', (self_id,)
            ).fetchone()[0]
            total_sent += sent
        print(f"消息总数:        {total_msgs:,}")
        print(f"聊天对象数:      {total_chats:,}")
        print(f"我发的消息数:    {total_sent:,}")
        print(f"对方发的消息数:  {total_msgs - total_sent:,}")
        # 时间跨度
        first, last = None, None
        for t in tables[:50]:  # 抽样
            r = conn.execute(f'SELECT MIN(create_time), MAX(create_time) FROM "{t}" WHERE create_time>0').fetchone()
            if r[0]:
                first = min(first or r[0], r[0])
                last = max(last or r[1], r[1])
        if first and last:
            print(f"时间跨度:        {datetime.fromtimestamp(first).date()} 至 {datetime.fromtimestamp(last).date()}")
        return

    if args.action in ("top-contacts", "top-groups"):
        is_group_mode = args.action == "top-groups"
        ranks = []
        for t in tables:
            uname = n2t.get(t, "")
            if not uname: continue
            is_group = uname.endswith("@chatroom")
            if is_group_mode and not is_group: continue
            if not is_group_mode and is_group: continue
            cnt = conn.execute(f'SELECT COUNT(*) FROM "{t}"').fetchone()[0]
            if cnt == 0: continue
            ranks.append((uname, cnt))
        ranks.sort(key=lambda x: -x[1])
        n = args.n or 20
        kind = "群" if is_group_mode else "联系人"
        print(f"消息量 top {min(n, len(ranks))} {kind}（共 {len(ranks)} 个）:\n")
        for uname, cnt in ranks[:n]:
            print(f"  {cnt:6d}  {display(uname)}")
        return

    if args.action == "monthly":
        # 全表按月聚合（用 create_time）
        agg = {}
        for t in tables:
            for ym, cnt in conn.execute(
                f"SELECT strftime('%Y-%m', create_time, 'unixepoch','localtime') AS ym, COUNT(*) "
                f'FROM "{t}" WHERE create_time > 0 GROUP BY ym'
            ).fetchall():
                agg[ym] = agg.get(ym, 0) + cnt
        print("每月消息量（含收发双方）:\n")
        for ym in sorted(agg.keys()):
            bar = "█" * min(60, agg[ym] // max(1, max(agg.values()) // 60))
            print(f"  {ym}  {agg[ym]:6d}  {bar}")
        return

    if args.action == "hourly":
        agg = [0] * 24
        for t in tables:
            for hour, cnt in conn.execute(
                f"SELECT CAST(strftime('%H', create_time, 'unixepoch','localtime') AS INTEGER) AS h, COUNT(*) "
                f'FROM "{t}" WHERE create_time > 0 GROUP BY h'
            ).fetchall():
                agg[hour] += cnt
        m = max(agg)
        print("24h 消息分布:\n")
        for h in range(24):
            bar = "█" * (agg[h] * 50 // m)
            print(f"  {h:02d}时  {agg[h]:6d}  {bar}")
        return

    print(f"未知 action: {args.action}", file=sys.stderr); sys.exit(2)


def _biz_db():
    from vchat_core import _compat as mcp_server
    return mcp_server._cache.get("message/biz_message_0.db")


def _article_key(url):
    """URL 里取 __biz+mid+idx+sn 做去重 key，chksm 动态变不能用"""
    import re
    if not url:
        return ""
    parts = {}
    for k in ("__biz", "mid", "idx", "sn"):
        m = re.search(rf"[?&]{k}=([^&]+)", url)
        if m: parts[k] = m.group(1)
    return f"{parts.get('__biz','')}#{parts.get('mid','')}#{parts.get('idx','')}#{parts.get('sn','')}"


def _parse_biz_xml(text):
    """公众号文章 XML 解析。一条推送可能含多篇文章（mmreader/category/item）。返回 list[dict]"""
    import xml.etree.ElementTree as ET
    if not text:
        return []
    try:
        root = ET.fromstring(text)
    except ET.ParseError:
        return []
    appmsg = root.find("appmsg")
    if appmsg is None:
        return []
    cat = appmsg.find(".//mmreader/category")
    biz_name = cat.findtext("name") if cat is not None else ""
    articles = []
    # topnew (头条) + items (副条)
    if cat is not None:
        topnew = cat.find("topnew")
        if topnew is not None:
            articles.append({
                "biz": biz_name,
                "title": appmsg.findtext("title") or "",
                "url": appmsg.findtext("url") or "",
                "digest": (appmsg.findtext("des") or "").strip(),
                "cover": topnew.findtext("cover") or "",
            })
        for it in cat.findall("item"):
            articles.append({
                "biz": biz_name,
                "title": it.findtext("title") or "",
                "url": it.findtext("url") or "",
                "digest": (it.findtext("digest") or "").strip(),
                "cover": it.findtext("cover") or "",
            })
    if not articles:  # fallback: 用 appmsg 顶层
        articles.append({
            "biz": biz_name or "?",
            "title": appmsg.findtext("title") or "",
            "url": appmsg.findtext("url") or "",
            "digest": (appmsg.findtext("des") or "").strip(),
            "cover": "",
        })
    return articles


def cmd_biz(args):
    """公众号订阅历史 ls/accounts/search/articles"""
    check_freshness()
    import sqlite3
    from vchat_core import _compat as mcp_server
    db = _biz_db()
    if not db:
        print("拿不到 biz_message_0.db", file=sys.stderr)
        sys.exit(2)
    conn = sqlite3.connect(db)
    tables = [r[0] for r in conn.execute(
        "SELECT name FROM sqlite_master WHERE type='table' AND name LIKE 'Msg_%'"
    ).fetchall()]
    names = mcp_server.get_contact_names() or {}
    BIZ_TYPE = 21474836529  # 公众号文章推送

    def _table_for_biz(query):
        """从联系人名解析到该公众号的 Msg 表名"""
        ctx = mcp_server._resolve_chat_context(query)
        if not ctx:
            return None, None
        username = ctx["username"]
        # Name2Id 表里 user_name → 哪张 Msg_<hash>
        row = conn.execute("SELECT user_name FROM Name2Id WHERE user_name=?", (username,)).fetchone()
        if not row:
            return None, ctx["display_name"]
        import hashlib
        h = hashlib.md5(username.encode()).hexdigest()
        tbl = f"Msg_{h}"
        if tbl not in tables:
            return None, ctx["display_name"]
        return tbl, ctx["display_name"]

    if args.action == "accounts":
        # 按消息数排序公众号列表
        stats = []
        for t in tables:
            cnt = conn.execute(f'SELECT COUNT(*) FROM "{t}" WHERE local_type=?', (BIZ_TYPE,)).fetchone()[0]
            if cnt == 0: continue
            # 反查 wxid: t = Msg_<md5(wxid)>
            stats.append((t, cnt))
        stats.sort(key=lambda x: -x[1])

        # 反查 wxid → name：扫 Name2Id 算 md5 匹配
        n2t = {}
        for r in conn.execute("SELECT user_name FROM Name2Id").fetchall():
            import hashlib
            h = hashlib.md5(r[0].encode()).hexdigest()
            n2t[f"Msg_{h}"] = r[0]

        n = args.n or 50
        print(f"看过文章的公众号 top {min(n,len(stats))}（共 {len(stats)} 个有文章的公众号）:\n")
        for tbl, cnt in stats[:n]:
            wxid = n2t.get(tbl, "?")
            name = names.get(wxid, wxid)
            print(f"  {cnt:5d} 篇  {name}  ({wxid})")
        return

    if args.action == "ls":
        # 全库最近 N 条文章（合并所有 Msg 表）
        n = args.n or 20
        all_rows = []
        for t in tables:
            for row in conn.execute(
                f'SELECT create_time, message_content, WCDB_CT_message_content FROM "{t}" '
                f'WHERE local_type=? ORDER BY create_time DESC LIMIT ?',
                (BIZ_TYPE, n)
            ).fetchall():
                all_rows.append((t, row[0], row[1], row[2]))
        all_rows.sort(key=lambda x: -x[1])
        all_rows = all_rows[:n]

        seen = set()
        shown = 0
        for tbl, ct, mc, wcdb_ct in all_rows:
            decoded = mcp_server._decompress_content(mc, wcdb_ct)
            for art in _parse_biz_xml(decoded):
                k = _article_key(art['url'])
                if k and k in seen: continue
                seen.add(k)
                when = datetime.fromtimestamp(ct).strftime("%m-%d %H:%M")
                print(f"[{when}] [{art['biz']}] {art['title']}")
                if art['digest']:
                    print(f"  {art['digest'][:100]}")
                if art['url']:
                    print(f"  {art['url']}")
                print()
                shown += 1
                if shown >= n: return
        return

    if args.action == "search":
        kw = args.target
        if not kw:
            print("search 需要关键词", file=sys.stderr); sys.exit(2)
        n = args.n or 30
        # message_content 是 zstd 压缩的，SQL LIKE 搜不到，全量解压扫
        kw_lower = kw.lower()
        seen = set()
        hits = []
        scanned = 0
        for t in tables:
            rows = conn.execute(
                f'SELECT create_time, message_content, WCDB_CT_message_content FROM "{t}" '
                f'WHERE local_type=? ORDER BY create_time DESC',
                (BIZ_TYPE,)
            ).fetchall()
            for ct, mc, wcdb_ct in rows:
                scanned += 1
                decoded = mcp_server._decompress_content(mc, wcdb_ct)
                if not decoded or kw_lower not in str(decoded).lower():
                    continue
                for art in _parse_biz_xml(decoded):
                    if kw_lower not in (art['title'] + art['digest']).lower():
                        continue
                    k = _article_key(art['url'])
                    if k and k in seen: continue
                    seen.add(k)
                    hits.append((ct, art))
                    if len(hits) >= n: break
                if len(hits) >= n: break
            if len(hits) >= n: break
        hits.sort(key=lambda x: -x[0])
        if not hits:
            print(f"没找到含「{kw}」的公众号文章（扫描 {scanned} 条）")
            return
        print(f"搜「{kw}」找到 {len(hits)} 条（扫描 {scanned} 条）:\n")
        for ct, art in hits:
            when = datetime.fromtimestamp(ct).strftime("%Y-%m-%d %H:%M")
            print(f"[{when}] [{art['biz']}] {art['title']}")
            if art['url']:
                print(f"  {art['url']}")
            print()
        return

    if args.action == "articles":
        if not args.target:
            print("articles 需要公众号名/wxid", file=sys.stderr); sys.exit(2)
        tbl, dname = _table_for_biz(args.target)
        if not tbl:
            print(f"找不到公众号: {args.target}", file=sys.stderr); sys.exit(2)
        n = args.n or 100
        rows = conn.execute(
            f'SELECT create_time, message_content, WCDB_CT_message_content FROM "{tbl}" '
            f'WHERE local_type=? ORDER BY create_time DESC LIMIT ?',
            (BIZ_TYPE, n)
        ).fetchall()
        seen = set()
        out = []
        for ct, mc, wcdb_ct in rows:
            decoded = mcp_server._decompress_content(mc, wcdb_ct)
            for art in _parse_biz_xml(decoded):
                k = _article_key(art['url'])
                if k and k in seen: continue
                seen.add(k)
                out.append((ct, art))
        print(f"{dname} 的文章历史（去重后 {len(out)} 篇）:\n")
        for ct, art in out:
            when = datetime.fromtimestamp(ct).strftime("%Y-%m-%d %H:%M")
            print(f"[{when}] {art['title']}")
            if art['url']:
                print(f"  {art['url']}")
        return

    print(f"未知 action: {args.action}", file=sys.stderr); sys.exit(2)


def cmd_avatar(args):
    """提取头像。head_image.db 里 image_buffer 直接就是 JPEG 字节。
    走 mcp_server._cache 拿最新解密快照（按 mtime 检测 + WAL patch），保证新加好友的头像也能拿到。
    """
    check_freshness()
    import sqlite3
    import os as _os
    from vchat_core import _compat as mcp_server
    db = mcp_server._cache.get(_os.path.join("head_image", "head_image.db"))
    if not db:
        print("DBCache 拿不到 head_image.db，可能 all_keys.json 过期，sudo wxrefresh", file=sys.stderr)
        sys.exit(2)

    out_dir = Path(args.output_dir or "~/Downloads").expanduser().resolve()
    out_dir.mkdir(parents=True, exist_ok=True)

    if args.all:
        with sqlite3.connect(db) as conn:
            rows = conn.execute(
                "SELECT username, image_buffer FROM head_image WHERE image_buffer IS NOT NULL"
            ).fetchall()
        ok = 0
        for uname, buf in rows:
            if not buf or buf[:3] != b"\xff\xd8\xff":
                continue
            safe = uname.replace("/", "_").replace("@", "_at_")
            (out_dir / f"{safe}.jpg").write_bytes(buf)
            ok += 1
        print(f"导出 {ok}/{len(rows)} 个头像到 {out_dir}")
        return

    # 按名字解析到 username
    ctx = mcp_server._resolve_chat_context(args.name)
    if not ctx:
        print(f"找不到联系人/群: {args.name}", file=sys.stderr)
        sys.exit(2)
    target = ctx["username"]

    if ctx.get("is_group"):
        # 群头像也走 head_image，username 是 chatroom id
        targets = [target]
    else:
        targets = [target]

    with sqlite3.connect(db) as conn:
        for uname in targets:
            row = conn.execute(
                "SELECT image_buffer FROM head_image WHERE username = ?", (uname,)
            ).fetchone()
            if not row or not row[0]:
                print(f"{uname}: 库里没有头像", file=sys.stderr)
                continue
            buf = row[0]
            if buf[:3] != b"\xff\xd8\xff":
                print(f"{uname}: image_buffer 不是 JPEG（前 4 字节 {buf[:4].hex()}）", file=sys.stderr)
                continue
            safe = uname.replace("/", "_").replace("@", "_at_")
            out_path = out_dir / f"{ctx['display_name']}_{safe}.jpg"
            out_path.write_bytes(buf)
            print(out_path)



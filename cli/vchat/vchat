def cmd_tags(args):
    """联系人标签 ls / members"""
    check_freshness()
    import sqlite3
    from vchat_core import _compat as core
    db = core._cache.get("contact/contact.db")
    if not db:
        print("❌ contact.db 不可用", file=sys.stderr); sys.exit(2)
    conn = sqlite3.connect(db)

    if args.action == "ls":
        rows = conn.execute("SELECT label_id_, label_name_, sort_order_ FROM contact_label ORDER BY sort_order_").fetchall()
        if not rows:
            print("（没有标签）"); return
        print(f"联系人标签（{len(rows)} 个）：")
        for lid, name, _ in rows:
            print(f"  [{lid:3d}]  {name}")
        return

    if args.action == "members":
        if not args.target:
            print("❌ vchat tags-members <标签名或id>", file=sys.stderr); sys.exit(2)
        try:
            label_id = int(args.target)
            row = conn.execute("SELECT label_name_ FROM contact_label WHERE label_id_=?", (label_id,)).fetchone()
            label_name = row[0] if row else f"id={label_id}"
        except ValueError:
            row = conn.execute("SELECT label_id_, label_name_ FROM contact_label WHERE label_name_=?", (args.target,)).fetchone()
            if not row:
                print(f"❌ 没有标签: {args.target}", file=sys.stderr); sys.exit(2)
            label_id, label_name = row

        rows = conn.execute(
            "SELECT username, nick_name, remark, extra_buffer FROM contact "
            "WHERE extra_buffer IS NOT NULL AND length(extra_buffer) > 2"
        ).fetchall()

        def _scan(buf, target):
            i, n = 0, len(buf)
            while i < n - 1:
                tag = buf[i]; i += 1
                wt = tag & 0x7
                if wt != 2:
                    if wt == 0:
                        while i < n and buf[i] & 0x80: i += 1
                        i += 1
                    elif wt == 1: i += 8
                    elif wt == 5: i += 4
                    else: break
                    continue
                length, shift = 0, 0
                while i < n and shift < 64:
                    b = buf[i]; i += 1
                    length |= (b & 0x7f) << shift
                    if not (b & 0x80): break
                    shift += 7
                if length <= 0 or length > 200 or i + length > n:
                    continue
                blk = buf[i:i+length]; i += length
                j = 0
                while j < len(blk):
                    val, shift = 0, 0
                    while j < len(blk) and shift < 64:
                        b = blk[j]; j += 1
                        val |= (b & 0x7f) << shift
                        if not (b & 0x80): break
                        shift += 7
                    if val == target: return True
                    if val > 200: break
            return False

        hits = []
        for u, n, r, eb in rows:
            if _scan(eb, label_id):
                hits.append((u, r or n or u))
        print(f"标签「{label_name}」(id={label_id}) 下的成员（启发式扫描）：")
        if not hits:
            print("  （没扫到）"); return
        print(f"  {len(hits)} 个候选：\n")
        for u, name in hits[:args.n or 200]:
            print(f"  {u:35s}  {name}")
        print("\n注：基于 extra_buffer protobuf 启发式扫描；精确度有限。")



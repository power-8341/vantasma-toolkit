def cmd_watch(args):
    """实时监听新消息（tail -f 风格）"""
    check_freshness()
    import sqlite3, time as _time, hashlib
    from vchat_core.cache import default_cache
    from vchat_core import _compat as core
    from vchat_core.messages import find_message_table, _build_sender_map

    target_username = None
    if args.chat:
        ctx = core._resolve_chat_context(args.chat)
        if not ctx:
            print(f"❌ 找不到: {args.chat}", file=sys.stderr); sys.exit(2)
        target_username = ctx["username"]
        print(f"▶ 监听 [{ctx['display_name']}]", file=sys.stderr)
    else:
        print(f"▶ 监听全部新消息", file=sys.stderr)

    names = core.get_contact_names() or {}
    cache = default_cache()
    res_path = cache._root / "message" / "message_resource.db"

    def _baseline():
        c = sqlite3.connect(f"file:{res_path}?mode=ro", uri=True)
        r = c.execute("SELECT MAX(message_id) FROM MessageResourceInfo").fetchone()
        c.close()
        return r[0] or 0

    last = _baseline()
    print(f"  基线 message_id = {last}", file=sys.stderr)

    def _chat_map():
        c = sqlite3.connect(f"file:{res_path}?mode=ro", uri=True)
        m = {r[0]: r[1] for r in c.execute("SELECT rowid, user_name FROM ChatName2Id").fetchall()}
        c.close()
        return m

    interval = args.interval or 5
    keyword = args.keyword
    try:
        while True:
            _time.sleep(interval)
            c = sqlite3.connect(f"file:{res_path}?mode=ro", uri=True)
            new_rows = c.execute(
                "SELECT message_id, chat_id, sender_id, message_local_type, "
                "message_create_time, message_local_id, message_svr_id "
                "FROM MessageResourceInfo WHERE message_id > ? "
                "ORDER BY message_id ASC LIMIT 200", (last,)
            ).fetchall()
            c.close()
            if not new_rows: continue
            chat_map = _chat_map()
            for mid, cid, snd_id, ltype, ct, local_id, svr_id in new_rows:
                last = mid
                chat_u = chat_map.get(cid, f"?cid={cid}")
                if target_username and chat_u != target_username: continue
                content = ""; sender = "?"
                try:
                    loc = find_message_table(chat_u)
                    if loc:
                        db_rel, table = loc
                        mc = cache.get(db_rel)
                        row = mc.execute(
                            f"SELECT message_content, real_sender_id FROM [{table}] WHERE local_id=? LIMIT 1",
                            (local_id,)).fetchone()
                        if row:
                            t = row["message_content"]
                            if isinstance(t, bytes):
                                try: t = t.decode("utf-8")
                                except: t = "<bytes>"
                            content = (t or "").replace("\n", " ")[:200]
                            smap = _build_sender_map(db_rel)
                            wxid = smap.get(row["real_sender_id"], "")
                            sender = names.get(wxid, wxid) if wxid else "[系统]"
                except Exception as e:
                    content = f"<err: {e}>"
                if keyword and keyword not in content: continue
                when = datetime.fromtimestamp(ct).strftime("%H:%M:%S") if ct else "?"
                chat_disp = names.get(chat_u, chat_u)
                tag = ""
                if ltype == 3: tag = "[图]"
                elif ltype == 34: tag = "[语音]"
                elif ltype == 43: tag = "[视频]"
                elif ltype == 47: tag = "[表情]"
                elif ltype == 49: tag = "[卡片]"
                print(f"[{when}] [{chat_disp}] {sender}: {tag}{content}")
                sys.stdout.flush()
    except KeyboardInterrupt:
        print(f"\n▶ 停止监听（最终 message_id = {last}）", file=sys.stderr)


def cmd_decrypt(args):
    """一键解密：扫内存 → 配 key → 解所有 db"""
    import platform
    from vchat_core.exitcodes import EX_UNAVAILABLE, EX_NOPERM, EX_SOFTWARE
    sys_name = platform.system()
    if sys_name not in ("Darwin", "Windows"):
        print(f"❌ 暂不支持 {sys_name}", file=sys.stderr); sys.exit(EX_UNAVAILABLE)
    from vchat_core.decrypt_pipeline import full_pipeline
    scanner = Path(__file__).resolve().parent / "vchat_native" / "find_keys_macos"
    cached_keys = DATA_DIR / "keys.json"
    try:
        summary = full_pipeline(scanner, DATA_DIR, cached_keys)
    except PermissionError as e:
        hint = "sudo vchat decrypt" if sys_name == "Darwin" else "以管理员身份运行 vchat decrypt"
        print(f"❌ {e}\n  → {hint}", file=sys.stderr); sys.exit(EX_NOPERM)
    except RuntimeError as e:
        print(f"❌ {e}", file=sys.stderr); sys.exit(EX_SOFTWARE)
    print(f"\n✅ 解密完成")
    print(f"  数据目录: {summary['data_dir']}")
    print(f"  匹配 keys: {summary['dbs_matched']} / {summary['dbs_total']}")
    print(f"  解密成功: {summary['dbs_decrypted_ok']}")
    if summary["dbs_failed"]:
        print(f"  失败: {summary['dbs_failed']}")
    print(f"\n试一下：vchat doctor → vchat ls 20")


def cmd_setup(args):
    """一键安装：检测环境 → codesign → 编译 native → 解密"""
    import platform
    from vchat_core.exitcodes import EX_UNAVAILABLE
    sys_name = platform.system()
    if sys_name == "Windows":
        print("▶ Windows · 直接跑 decrypt（无需 codesign / make）")
        cmd_decrypt(args); return
    if sys_name != "Darwin":
        print(f"❌ setup 暂不支持 {sys_name}", file=sys.stderr); sys.exit(EX_UNAVAILABLE)

    print("▶ 步骤 1/5 · 检查 WeChat.app")
    wechat = Path("/Applications/WeChat.app")
    if not wechat.exists():
        print(f"❌ 没找到 {wechat}", file=sys.stderr); sys.exit(2)
    print(f"  ✓ {wechat}")

    print("\n▶ 步骤 2/5 · ad-hoc codesign")
    if os.geteuid() != 0:
        print("⚠ 这步需要 sudo。请用 sudo vchat setup"); sys.exit(3)
    out = subprocess.run(["codesign", "--force", "--deep", "--sign", "-", str(wechat)],
                         capture_output=True, text=True)
    if out.returncode != 0:
        print(f"❌ codesign 失败:\n{out.stderr}", file=sys.stderr); sys.exit(4)
    print(f"  ✓ codesign 完成")

    print("\n▶ 步骤 3/5 · 编译 vchat_native/find_keys_macos")
    native_dir = Path(__file__).resolve().parent / "vchat_native"
    out = subprocess.run(["make", "-C", str(native_dir)], capture_output=True, text=True)
    if out.returncode != 0:
        print(f"❌ make 失败:\n{out.stderr}", file=sys.stderr); sys.exit(5)
    print(f"  ✓ {native_dir / 'find_keys_macos'}")

    print("\n▶ 步骤 4/5 · 检查 WeChat 是否运行")
    pid_out = subprocess.run(["pgrep", "-f", "WeChat.app/Contents/MacOS/WeChat$"],
                             capture_output=True, text=True)
    if pid_out.returncode != 0:
        print("❌ WeChat 没在跑"); sys.exit(6)
    print(f"  ✓ WeChat pid = {pid_out.stdout.split()[0]}")

    print("\n▶ 步骤 5/5 · 内存扫描 + 解密")
    cmd_decrypt(args)



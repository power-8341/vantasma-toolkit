def cmd_doctor(args):
    """数据目录健康检查（缺什么 db 一目了然）"""
    from vchat_core.exitcodes import EX_NOINPUT, EX_OSFILE
    json_mode = getattr(args, "json_out", False)

    required = {
        "contact/contact.db":    "联系人 / 群成员",
        "session/session.db":    "最近会话",
        "message/message_0.db":  "消息",
    }
    optional = {
        "message/media_0.db":      "媒体",
        "head_image/head_image.db":"头像",
        "favorite/favorite.db":    "收藏夹",
        "sns/sns.db":              "朋友圈",
    }

    if not DECRYPTED.exists():
        if json_mode:
            from vchat_core.output import emit
            emit({"data_dir": str(DATA_DIR), "exists": False,
                  "missing_required": list(required.keys())}, json_mode=True)
        else:
            print(f"数据目录: {DATA_DIR}")
            print(f"❌ {DECRYPTED} 不存在 — 先跑 sudo vchat setup")
        sys.exit(EX_NOINPUT)

    payload = {"data_dir": str(DATA_DIR), "decrypted_dir": str(DECRYPTED),
               "exists": True, "required": [], "optional": [],
               "message_shards": [], "missing_required": []}
    for rel, why in required.items():
        p = DECRYPTED / rel
        payload["required"].append({"path": rel, "purpose": why,
            "exists": p.exists(),
            "size_kb": (p.stat().st_size / 1024) if p.exists() else 0})
        if not p.exists():
            payload["missing_required"].append(rel)
    msg_dir = DECRYPTED / "message"
    for rel, why in optional.items():
        if rel == "message/media_0.db":
            shards = sorted(msg_dir.glob("media_*.db")) if msg_dir.exists() else []
            payload["optional"].append({"path": "message/media_*.db", "purpose": why,
                "exists": bool(shards), "shards": len(shards),
                "total_kb": sum(p.stat().st_size for p in shards) / 1024})
            continue
        p = DECRYPTED / rel
        payload["optional"].append({"path": rel, "purpose": why,
            "exists": p.exists(),
            "size_kb": (p.stat().st_size / 1024) if p.exists() else 0})
    if msg_dir.exists():
        for p in sorted(msg_dir.glob("message_*.db")):
            payload["message_shards"].append({"path": str(p.relative_to(DECRYPTED)),
                "size_mb": p.stat().st_size / (1024 * 1024)})

    if json_mode:
        from vchat_core.output import emit
        emit(payload, json_mode=True)
        if payload["missing_required"]:
            sys.exit(EX_OSFILE)
        return

    print(f"数据目录: {DATA_DIR}\n\n必需 db:")
    for it in payload["required"]:
        sym = "✅" if it["exists"] else "❌"
        sz = f"{it['size_kb']:>7.1f} KB" if it["exists"] else "缺失       "
        print(f"  {sym} {it['path']:30s}  {sz}  · {it['purpose']}")
    print("\n可选 db:")
    for it in payload["optional"]:
        sym = "✅" if it["exists"] else "⚪"
        if "shards" in it:
            print(f"  {sym} {it['path']} (×{it['shards']})  {it['total_kb']:>7.1f} KB  · {it['purpose']}")
        else:
            sz = f"{it['size_kb']:>7.1f} KB" if it["exists"] else "未提供     "
            print(f"  {sym} {it['path']:30s}  {sz}  · {it['purpose']}")
    if payload["message_shards"]:
        total = sum(s["size_mb"] for s in payload["message_shards"])
        print(f"\n消息分片: {len(payload['message_shards'])} 个，合计 {total:.1f} MB")
    print()
    if payload["missing_required"]:
        print(f"⚠️  缺 {len(payload['missing_required'])} 个必需 db")
        sys.exit(EX_OSFILE)
    print("✅ 必需 db 齐全，vchat 可正常工作。")



from vchat_core import get_data_dir, get_decrypted_dir

DATA_DIR = get_data_dir()
DECRYPTED = get_decrypted_dir()
# 兼容旧变量名（v1 时期的 cmd_* 函数有用到 PROJECT_DIR）
PROJECT_DIR = DATA_DIR
STALE_HOURS = 24 * 7  # 7 天


def _newest_db_mtime() -> float:
    if not DECRYPTED.exists():
        return 0.0
    mtimes = [p.stat().st_mtime for p in DECRYPTED.rglob("*.db")]
    return max(mtimes) if mtimes else 0.0


def check_freshness(quiet=False):
    if not DECRYPTED.exists():
        print(
            f"❌ 数据目录不存在: {DECRYPTED}\n"
            f"   先跑 `sudo vchat setup` 一键解密。",
            file=sys.stderr,
        )
        sys.exit(66)
    mt = _newest_db_mtime()
    if mt == 0:
        return None
    hours = (time.time() - mt) / 3600
    if not quiet and hours > STALE_HOURS:
        print(f"⚠ 最新 db 已经 {hours/24:.1f} 天没更新。",
              file=sys.stderr)
    return hours


def cmd_info(args):
    from vchat_core import __version__
    mt = _newest_db_mtime()
    db_count = len(list(DECRYPTED.rglob("*.db"))) if DECRYPTED.exists() else 0
    info_dict = {
        "version": __version__,
        "data_dir": str(DATA_DIR),
        "decrypted_dir": str(DECRYPTED),
        "decrypted_dir_exists": DECRYPTED.exists(),
        "newest_db_mtime": mt,
        "newest_db_iso": datetime.fromtimestamp(mt).isoformat() if mt else None,
        "db_count": db_count,
    }
    if getattr(args, "json_out", False):
        from vchat_core.output import emit
        emit(info_dict, json_mode=True); return
    print(f"数据目录: {DATA_DIR}")
    print(f"解密目录: {DECRYPTED} ({'存在' if DECRYPTED.exists() else '不存在'})")
    if mt > 0:
        when = datetime.fromtimestamp(mt).strftime("%Y-%m-%d %H:%M:%S")
        hours = (time.time() - mt) / 3600
        ago = f"{hours:.1f}h" if hours < 48 else f"{hours/24:.1f}d"
        print(f"最新 db 修改: {when}  ({ago} 前)")
    else:
        print("最新 db 修改: 数据目录里没有任何 .db")
    print("追新机制: vchat_core.cache 按 mtime 自动检测重连。")
    print(f"已解密 db 数: {db_count}")



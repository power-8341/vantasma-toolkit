def cmd_money(args):
    """转账 + 红包历史。转账金额从 message_*.db 的 wcpayinfo 提取；红包金额库里没存（微信设计）"""
    check_freshness()
    import sqlite3, hashlib, re
    from vchat_core import _compat as mcp_server
    db_g = mcp_server._cache.get(os.path.join("general", "general.db"))
    if not db_g:
        print("拿不到 general.db", file=sys.stderr); sys.exit(2)
    names = mcp_server.get_contact_names() or {}
    self_id = mcp_server._get_self_username()

    with sqlite3.connect(db_g) as conn:
        transfers = conn.execute(
            "SELECT message_server_id, second_message_server_id, begin_transfer_time, session_name, pay_payer, pay_receiver "
            "FROM transferTable ORDER BY begin_transfer_time DESC"
        ).fetchall()
        reds = conn.execute(
            "SELECT message_server_id, session_name, sender_user_name "
            "FROM redEnvelopeTable ORDER BY message_server_id DESC"
        ).fetchall()

    # JOIN 转账 → message_0.db Msg_<md5(session)>.server_id = msg_id
    db_m = mcp_server._cache.get(os.path.join("message", "message_0.db"))
    msg_conn = sqlite3.connect(db_m) if db_m else None

    def fetch_transfer_detail(msg_id, second_id, session):
        """从 message_0.db JOIN 拿到金额 + 备注"""
        if not msg_conn: return None, None
        tbl = f"Msg_{hashlib.md5(session.encode()).hexdigest()}"
        # 检查表存在
        if not msg_conn.execute("SELECT name FROM sqlite_master WHERE name=?", (tbl,)).fetchone():
            return None, None
        # 试 message_server_id 和 second_message_server_id
        for sid in (msg_id, second_id):
            if not sid: continue
            r = msg_conn.execute(
                f'SELECT message_content, WCDB_CT_message_content FROM "{tbl}" WHERE server_id=?',
                (sid,)
            ).fetchone()
            if not r: continue
            mc, wcdb = r
            decoded = mcp_server._decompress_content(mc, wcdb) or ""
            fee = re.search(r"<feedesc>(?:<!\[CDATA\[)?([^<\]]+)", str(decoded))
            memo = re.search(r"<pay_memo>(?:<!\[CDATA\[)?([^<\]]+)", str(decoded))
            return (fee.group(1) if fee else None, memo.group(1) if memo else None)
        return None, None

    def fetch_red_time(msg_id, session):
        """红包没金额，至少拿个 create_time"""
        if not msg_conn: return 0
        tbl = f"Msg_{hashlib.md5(session.encode()).hexdigest()}"
        if not msg_conn.execute("SELECT name FROM sqlite_master WHERE name=?", (tbl,)).fetchone():
            return 0
        r = msg_conn.execute(f'SELECT create_time FROM "{tbl}" WHERE server_id=?', (msg_id,)).fetchone()
        return r[0] if r else 0

    def display(uname):
        return names.get(uname) or uname or "?"

    events = []
    for msg_id, second_id, ts, sess, payer, recv in transfers:
        direction = "→" if payer == self_id else "←" if recv == self_id else "↔"
        other = display(recv if payer == self_id else payer)
        amount, memo = fetch_transfer_detail(msg_id, second_id, sess)
        events.append((ts, "转账", direction, other, display(sess), amount or "?", memo or ""))
    for sid, sess, sender in reds:
        ts = fetch_red_time(sid, sess)
        direction = "→" if sender == self_id else "←"
        events.append((ts, "红包", direction, display(sender), display(sess), "(本地无)", ""))

    events.sort(key=lambda e: -(e[0] or 0))
    if msg_conn: msg_conn.close()

    n = args.n or 40
    transfer_total_in = sum(1 for e in events if e[1] == "转账" and e[2] == "←")
    transfer_total_out = sum(1 for e in events if e[1] == "转账" and e[2] == "→")
    print(f"转账 {len(transfers)} 条（收 {transfer_total_in} / 付 {transfer_total_out}） + 红包 {len(reds)} 条")
    print("红包金额微信本地不存（设计如此），转账金额从消息内容里提取\n")
    print(f"{'日期':<19}  {'类型':<4}  {'方向':<3}  {'金额':<10}  {'对方/发送者':<20}  群/对话  备注")
    for ts, kind, direction, other, chat, amount, memo in events[:n]:
        when = datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M") if ts else "(?)"
        chat_short = chat if chat == other else chat[:14]
        memo_short = f"📝{memo[:20]}" if memo else ""
        print(f"  {when}  {kind}  {direction}  {amount:<10}  {other[:18]:<18s}  {chat_short:<20s}  {memo_short}")


def cmd_stats(args):

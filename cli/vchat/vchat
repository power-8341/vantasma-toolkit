def cmd_search_fast(args):
    """走 message_fts.db 集中索引（180k 行）快速全库搜"""
    check_freshness()
    import sqlite3
    from vchat_core.cache import default_cache
    fts_path = default_cache()._root / "message" / "message_fts.db"
    if not fts_path.exists():
        print("❌ message_fts.db 不存在", file=sys.stderr); sys.exit(2)
    conn = sqlite3.connect(f"file:{fts_path}?mode=ro", uri=True)
    id2name = {r[0]: r[1] for r in conn.execute("SELECT rowid, username FROM name2id").fetchall()}
    from vchat_core import _compat as core
    names = core.get_contact_names() or {}
    pat = f"%{args.keyword}%"
    limit = args.n or 30
    out = [f"全库 FTS 搜「{args.keyword}」(limit {limit}):"]
    hits = 0
    for shard in range(4):
        if hits >= limit: break
        tbl = f"message_fts_v4_{shard}_content"
        try:
            rows = conn.execute(
                f"SELECT c0, c4, c5, c6 FROM {tbl} WHERE c0 LIKE ? ORDER BY c6 DESC LIMIT ?",
                (pat, limit - hits)
            ).fetchall()
        except sqlite3.OperationalError:
            continue
        for content, sid, snd, ct in rows:
            when = datetime.fromtimestamp(ct).strftime("%Y-%m-%d %H:%M") if ct else "?"
            sess_u = id2name.get(sid, f"?sid={sid}")
            sess = names.get(sess_u, sess_u)
            snd_u = id2name.get(snd, "")
            snd_n = names.get(snd_u, snd_u) if snd_u else ""
            line = f"  [{when}] [{sess}]"
            if snd_n: line += f" {snd_n}:"
            line += f" {(content or '').replace(chr(10), ' ')[:120]}"
            out.append(line)
            hits += 1
            if hits >= limit: break
    print("\n".join(out) if hits else f"全库未搜到「{args.keyword}」")


